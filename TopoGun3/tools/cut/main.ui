       <attribute name="buttonGroup">
        <string notr="true">buttonGroup</string>
       </attribute>
      </widget>
     </item>
     <item>
      <widget class="QRadioButton" name="cut_freeHand">
       <property name="toolTip">
        <string>切割路径通过在其上绘制几何体来创建。松开鼠标左键后，会通过计算边与绘制的切割路径之间的交点自动创建切割线。</string>
