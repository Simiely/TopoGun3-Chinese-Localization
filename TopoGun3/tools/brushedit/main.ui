     <item row="0" column="0">
      <widget class="QRadioButton" name="brushEdit_move">
       <property name="toolTip">
        <string>在移动模式下，顶点在参考网格表面移动。</string>
       </property>
       <property name="text"><string>移动</string></property>
       <property name="checked">
